# next to docker-compose.yml for `docker compose up`). Never commit real secrets.

# =============================================
# DATABASE
# =============================================
DB_USER=postgres
DB_PASSWORD=change-me
DB_NAME=lanna_db
# Supabase only: DATABASE_URL is the pooled (port 6543, ?pgbouncer=true) connection,
# DIRECT_URL is the direct (port 5432) connection used for migrations/CLI only.
# Leave DIRECT_URL unset for local/docker-compose Postgres — prisma.config.ts falls
# back to DATABASE_URL in that case.
DIRECT_URL=

# =============================================
# JWT
# =============================================
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# =============================================
# ENCRYPTION (AES-256, 32 chars)
# =============================================
ENCRYPTION_KEY=

# =============================================
# CLOUDFLARE R2
# =============================================
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=mbu-lanna-documents
R2_PUBLIC_URL=

# =============================================
# GOOGLE DRIVE BACKUP
# =============================================
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_DRIVE_FOLDER_ID=

# =============================================
# CLOUDFLARE TURNSTILE
# =============================================
TURNSTILE_SECRET_KEY=
# Public site key used by the frontend Turnstile widget — paired with the secret key above
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# =============================================
# BACKUP CRON
# =============================================
# Shared secret checked against the Authorization: Bearer header on
# POST /api/backup/cron (the scheduled-backup trigger endpoint).
CRON_SECRET=

# =============================================
# APP URLS
# =============================================
# Public URL the browser uses to reach the backend (baked into the frontend build)
NEXT_PUBLIC_API_URL=http://localhost:4000/api
# Backend's allowed CORS origin (the frontend's public URL)
FRONTEND_URL=http://localhost:3000
# Vercel only: server-side URL the frontend's Next.js rewrites proxy to (not
# NEXT_PUBLIC_ — never sent to the browser). Leave unset for docker-compose,
# where the frontend calls NEXT_PUBLIC_API_URL directly instead.
BACKEND_INTERNAL_URL=
