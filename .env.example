# Copy this to a Portainer stack "Environment variables" section (or a local .env
# next to docker-compose.yml for `docker compose up`). Never commit real secrets.

# =============================================
# DATABASE
# =============================================
DB_USER=postgres
DB_PASSWORD=change-me
DB_NAME=lanna_db

# =============================================
# JWT
# =============================================
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# =============================================
# ENCRYPTION (AES-256, 32 chars)
# =============================================
ENCRYPTION_KEY=

# =============================================
# CLOUDFLARE R2
# =============================================
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=mbu-lanna-documents
R2_PUBLIC_URL=

# =============================================
# GOOGLE DRIVE BACKUP
# =============================================
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_DRIVE_FOLDER_ID=

# =============================================
# CLOUDFLARE TURNSTILE
# =============================================
TURNSTILE_SECRET_KEY=

# =============================================
# APP URLS
# =============================================
# Public URL the browser uses to reach the backend (baked into the frontend build)
NEXT_PUBLIC_API_URL=http://localhost:4000/api
# Backend's allowed CORS origin (the frontend's public URL)
FRONTEND_URL=http://localhost:3000
