// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =============================================
// Admin Users
// =============================================
model Admin {
  id                  String    @id @default(cuid())
  email               String    @unique
  passwordHash        String    @map("password_hash")
  fullName            String    @map("full_name")
  role                AdminRole @default(STAFF)
  isActive            Boolean   @default(true) @map("is_active")
  lastLoginAt         DateTime? @map("last_login_at")
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime? @map("locked_until")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  @@map("admins")
}

enum AdminRole {
  SUPER_ADMIN
  STAFF
}

// =============================================
// Applicant (ผู้สมัคร)
// =============================================
model Applicant {
  id String @id @default(cuid())

  // ข้อมูลส่วนตัว
  prefixName  String  @map("prefix_name") // คำนำหน้า
  firstName   String  @map("first_name") // ชื่อ
  lastName    String  @map("last_name") // นามสกุล
  aliasName   String? @map("alias_name") // ฉายา (สำหรับพระภิกษุสามเณร)
  firstNameEn String? @map("first_name_en")
  lastNameEn  String? @map("last_name_en")
  nationalId  String  @unique @map("national_id") // เลขบัตรประชาชน (encrypted)
  nationalIdHash String? @unique @map("national_id_hash") // HMAC ของเลขบัตรประชาชน (deterministic, ใช้ค้นหา/ตรวจสอบซ้ำ)
  gender      Gender
  birthDate   DateTime @map("birth_date")
  ethnicity   String // เชื้อชาติ
  nationality String // สัญชาติ
  religion    String // ศาสนา
  bloodType   String? @map("blood_type")

  // ข้อมูลติดต่อ
  phone  String
  email  String?
  lineId String? @map("line_id")

  // ที่อยู่
  address     String
  subDistrict String @map("sub_district") // ตำบล
  district    String // อำเภอ
  province    String // จังหวัด
  postalCode  String @map("postal_code") // รหัสไปรษณีย์

  // ข้อมูลการศึกษา
  previousSchool    String  @map("previous_school")
  previousEducation String  @map("previous_education")
  gpa               Float?
  graduationYear    String? @map("graduation_year")
  schoolProvince    String? @map("school_province") // จังหวัดของโรงเรียน
  applicationReason String? @map("application_reason") @db.Text // เหตุผลการสมัครเรียน

  // รายการเอกสารที่แนบมา (เพื่อใช้ในการทำ PDF Checklist)
  hasTranscript        Boolean @default(false) @map("has_transcript")
  hasHouseRegistration Boolean @default(false) @map("has_house_registration")
  hasIdCard            Boolean @default(false) @map("has_id_card")
  hasNameChange        Boolean @default(false) @map("has_name_change")
  hasPhoto             Boolean @default(false) @map("has_photo")

  // หลักสูตรที่สมัคร
  programId String  @map("program_id")
  program   Program @relation(fields: [programId], references: [id])

  // สถานะ
  status            ApplicationStatus @default(PENDING)
  applicationNumber String            @unique @map("application_number")
  applicationYear   Int               @map("application_year")

  // ผลสอบ / รายงานตัว
  examResult     ExamResult     @default(NOT_YET) @map("exam_result")
  reportInStatus ReportInStatus @default(NOT_YET) @map("report_in_status")
  reportInReason String?        @db.Text @map("report_in_reason")
  reportInAt     DateTime?      @map("report_in_at")

  // ข้อมูลผู้ปกครอง
  parentName     String? @map("parent_name")
  parentPhone    String? @map("parent_phone")
  parentRelation String? @map("parent_relation")

  // PDPA consent
  pdpaConsent   Boolean  @default(false) @map("pdpa_consent")
  consentedAt   DateTime? @map("consented_at")

  // Timestamps
  submittedAt DateTime  @default(now()) @map("submitted_at")
  reviewedAt  DateTime? @map("reviewed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Review outcome
  rejectionReason String? @map("rejection_reason") @db.Text

  // Relations
  documents Document[]

  @@index([nationalId])
  @@index([applicationNumber])
  @@index([status])
  @@index([applicationYear])
  @@index([firstName, lastName])
  @@map("applicants")
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum ApplicationStatus {
  PENDING
  REVIEWING
  APPROVED
  REJECTED
  CANCELLED
}

enum ExamResult {
  NOT_YET
  PASSED
  FAILED
}

enum ReportInStatus {
  NOT_YET
  CONFIRMED
  REJECTED
}

// =============================================
// Faculties (คณะ)
// =============================================
model Faculty {
  id   String @id @default(cuid())
  name String @unique

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  programs Program[]

  @@map("faculties")
}

// =============================================
// Programs (หลักสูตร)
// =============================================
model Program {
  id          String       @id @default(cuid())
  name        String  // ชื่อหลักสูตร
  nameEn      String?      @map("name_en")
  facultyId   String       @map("faculty_id")
  faculty     Faculty      @relation(fields: [facultyId], references: [id])
  degree      String  // ระดับปริญญา (ปริญญาตรี/โท/เอก)
  track       ProgramTrack @default(REGULAR) // ภาคปกติ/ภาคพิเศษ
  description String? // หมายเหตุเพิ่มเติม (เช่น ภาคพิเศษ, เรียนเสาร์-อาทิตย์)
  curriculum  String? @db.Text // เรียนเกี่ยวกับอะไรบ้าง
  skills      String? @db.Text // ทักษะ/ความรู้ที่จะได้รับ
  careerPaths String? @map("career_paths") @db.Text // แนวทางอาชีพหลังจบการศึกษา
  duration    Int? // ระยะเวลาหลักสูตร (ปี)
  maxQuota    Int          @default(50) @map("max_quota") // จำนวนที่เปิดรับ
  isActive    Boolean      @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  applicants Applicant[]

  @@map("programs")
}

enum ProgramTrack {
  REGULAR
  SPECIAL
}

// =============================================
// Documents (เอกสารแนบ)
// =============================================
model Document {
  id          String       @id @default(cuid())
  applicantId String       @map("applicant_id")
  applicant   Applicant    @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  type        DocumentType
  fileName    String       @map("file_name")
  fileSize    Int          @map("file_size")
  mimeType    String       @map("mime_type")
  storageKey  String       @map("storage_key") // storage object key
  uploadedAt  DateTime     @default(now()) @map("uploaded_at")

  @@index([applicantId])
  @@map("documents")
}

enum DocumentType {
  PHOTO
  ID_CARD
  HOUSE_REGISTRATION
  TRANSCRIPT
  CERTIFICATE
  NAME_CHANGE
  OTHER
}

// =============================================
// Audit Logs
// =============================================
model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String?  @map("entity_id")
  adminId   String?  @map("admin_id")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  details   Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([entity, entityId])
  @@index([adminId])
  @@map("audit_logs")
}
